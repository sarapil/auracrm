{
  "name": "Auto Dialer Entry",
  "doctype": "DocType",
  "module": "AuraCRM",
  "engine": "InnoDB",
  "field_order": [
    "campaign",
    "priority",
    "cb_entry_top",
    "phone_number",
    "contact_name",
    "sb_reference",
    "reference_doctype",
    "reference_name",
    "cb_ref",
    "status",
    "disposition",
    "sb_call_details",
    "assigned_agent",
    "call_log_doctype",
    "call_log",
    "cb_call",
    "attempts",
    "last_attempt",
    "next_retry_at",
    "sb_result",
    "call_duration",
    "cb_result",
    "notes"
  ],
  "fields": [
    {
      "fieldname": "campaign",
      "fieldtype": "Link",
      "label": "Campaign",
      "options": "Auto Dialer Campaign",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "priority",
      "fieldtype": "Int",
      "label": "Priority",
      "default": "0",
      "description": "Higher number = higher priority in queue"
    },
    {
      "fieldname": "cb_entry_top",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "phone_number",
      "fieldtype": "Data",
      "label": "Phone Number",
      "reqd": 1,
      "in_list_view": 1,
      "options": "Phone"
    },
    {
      "fieldname": "contact_name",
      "fieldtype": "Data",
      "label": "Contact Name",
      "in_list_view": 1
    },
    {
      "fieldname": "sb_reference",
      "fieldtype": "Section Break",
      "label": "Reference"
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Link",
      "label": "Reference DocType",
      "options": "DocType"
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "label": "Reference Name",
      "options": "reference_doctype"
    },
    {
      "fieldname": "cb_ref",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "\nPending\nScheduled\nDialing\nRinging\nAnswered\nNo Answer\nBusy\nFailed\nCompleted\nSkipped\nDNC",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "disposition",
      "fieldtype": "Select",
      "label": "Disposition",
      "options": "\nAnswered\nNo Answer\nBusy\nFailed\nVoicemail\nCallback Requested\nNot Interested\nWrong Number\nDo Not Call"
    },
    {
      "fieldname": "sb_call_details",
      "fieldtype": "Section Break",
      "label": "Call Details"
    },
    {
      "fieldname": "assigned_agent",
      "fieldtype": "Link",
      "label": "Assigned Agent",
      "options": "User"
    },
    {
      "fieldname": "call_log_doctype",
      "fieldtype": "Link",
      "label": "Call Log DocType",
      "options": "DocType",
      "hidden": 1
    },
    {
      "fieldname": "call_log",
      "fieldtype": "Dynamic Link",
      "label": "Call Log",
      "options": "call_log_doctype",
      "description": "Link to AZ Call Log or Communication"
    },
    {
      "fieldname": "cb_call",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "attempts",
      "fieldtype": "Int",
      "label": "Attempts",
      "default": "0"
    },
    {
      "fieldname": "last_attempt",
      "fieldtype": "Datetime",
      "label": "Last Attempt"
    },
    {
      "fieldname": "next_retry_at",
      "fieldtype": "Datetime",
      "label": "Next Retry At",
      "description": "Scheduled time for next retry attempt"
    },
    {
      "fieldname": "sb_result",
      "fieldtype": "Section Break",
      "label": "Result"
    },
    {
      "fieldname": "call_duration",
      "fieldtype": "Int",
      "label": "Call Duration (sec)"
    },
    {
      "fieldname": "cb_result",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Sales User",
      "read": 1,
      "write": 1
    }
  ],
  "naming_rule": "Expression (old style)",
  "autoname": "format:ADE-{####}",
  "is_submittable": 0,
  "istable": 0,
  "sort_field": "modified",
  "sort_order": "DESC"
}